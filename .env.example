# --- Google Drive / Sheets service account ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
DRIVE_INVENTORY_FILE_ID=
DRIVE_INVOICE_FOLDER_ID=

# --- Email alerts: choose ONE provider ---
# resend (default) | gmail
EMAIL_PROVIDER=gmail

# Resend (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# Gmail SMTP via nodemailer (used when EMAIL_PROVIDER=gmail).
# Auth option A — App Password (requires 2-Step Verification on the Google account):
GMAIL_USER=alerts@growopfarms.com
GMAIL_APP_PASSWORD=
# Auth option B — OAuth2 (preferred when these are set):
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# From address. Defaults to GMAIL_USER when EMAIL_PROVIDER=gmail.
ALERT_FROM_EMAIL=
# Comma-separated recipients. If unset, falls back to the four hardcoded defaults in lib/email.ts.
ALERT_TO_EMAILS=tylerm@growopfarms.com,doviatt@growopfarms.com,charles@finishedgoods.com,luke@finishedgoods.com

# --- Cron protection ---
CRON_SECRET=

# --- Vercel KV snapshot store ---
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Tunables ---
TARGET_DAYS=120
